  "system": {
    "version": "1.0.0",
    "environment": "development",
    "logging": {
      "level": "info",
      "enableConsole": true,
      "enableFile": true,
      "enableAudit": true
    },
    "performance": {
      "maxConcurrency": 4,
      "timeoutMs": 30000,
      "enableParallelExecution": true
    },
    "security": {
      "enableApiKeyValidation": true,
      "enableRateLimiting": true,
      "maxRequestsPerMinute": 100
    },
    "features": {
      "enableAutoFix": false,
      "enableDetailedReporting": true,
      "enableRealTimeMonitoring": true
    }
  },
  "rules": [
    {
      "id": "unused-state-variables",
      "name": "Unused State Variables",
      "enabled": true,
      "severity": "medium",
      "category": "soroban",
      "language": "rust",
      "description": "Identifies state variables in Soroban contracts that are never read or written to",
      "parameters": {
        "ignoreVariables": [],
        "checkConstructor": true
      },
      "dependencies": [],
      "tags": ["performance", "storage", "soroban"]
    },
    {
      "id": "uint8-vs-uint256",
      "name": "Uint8 vs Uint256 Rule",
      "enabled": true,
      "severity": "low",
      "category": "solidity",
      "language": "solidity",
      "description": "Checks for inefficient use of uint256 when smaller types could be used",
      "parameters": {
        "maxSize": 256,
        "checkMappings": true
      },
      "dependencies": [],
      "tags": ["performance", "gas-optimization", "solidity"]
    },
    {
      "id": "reentrancy-guard",
      "name": "Reentrancy Guard",
      "enabled": true,
      "severity": "critical",
      "category": "security",
      "language": "solidity",
      "description": "Detects potential reentrancy vulnerabilities",
      "parameters": {
        "checkExternalCalls": true,
        "checkStateChanges": true
      },
      "dependencies": [],
      "tags": ["security", "reentrancy", "solidity"]
    },
    {
      "id": "use-safe-int-types",
      "name": "Use Safe Integer Types",
      "enabled": true,
      "severity": "medium",
      "category": "best-practices",
      "language": "rust",
      "description": "Flags uses of i128/u128 where smaller bounded integer types would suffice for Soroban contracts",
      "parameters": {
        "allowAmountParams": true
      },
      "dependencies": [],
      "tags": ["best-practices", "integer-types", "gas-optimization", "soroban"]
    },
    {
      "id": "use-immutable-storage",
      "name": "Use Immutable Storage for Read-Only Data",
      "enabled": true,
      "severity": "medium",
      "category": "best-practices",
      "language": "rust",
      "description": "Flags storage writes in functions that follow read-only naming conventions",
      "parameters": {
        "checkViewFunctions": true
      },
      "dependencies": [],
      "tags": ["best-practices", "storage", "view-functions", "soroban"]
    },
    {
      "id": "use-checked-arithmetic",
      "name": "Use Checked Arithmetic",
      "enabled": true,
      "severity": "high",
      "category": "best-practices",
      "language": "rust",
      "description": "Flags arithmetic operations that could overflow without checked methods",
      "parameters": {
        "allowLoopCounters": true
      },
      "dependencies": [],
      "tags": ["best-practices", "arithmetic", "overflow", "soroban"]
    },
    {
      "id": "use-result-types",
      "name": "Use Result Return Types",
      "enabled": true,
      "severity": "medium",
      "category": "best-practices",
      "language": "rust",
      "description": "Flags functions that use fallible operations like unwrap without returning Result",
      "parameters": {
        "checkStorageReads": true,
        "checkCrossContractCalls": true
      },
      "dependencies": [],
      "tags": ["best-practices", "error-handling", "result-types", "soroban"]
    },
    {
      "id": "use-initialization-functions",
      "name": "Use Initialization Functions",
      "enabled": true,
      "severity": "high",
      "category": "best-practices",
      "language": "rust",
      "description": "Flags Soroban contracts that lack a constructor despite performing storage initialization",
      "parameters": {
        "requireConstructor": true
      },
      "dependencies": [],
      "tags": ["best-practices", "initialization", "constructor", "soroban"]
    }
  ],
  "profiles": [
