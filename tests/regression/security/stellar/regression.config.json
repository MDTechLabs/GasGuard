  "ci": {
    "command": "npx jest --testPathPattern 'tests/regression/security/stellar' --verbose",
    "required": true,
    "onFailure": "block-release"
  },
  "snapshot": {
    "enabled": true,
    "dir": "__snapshots__",
    "autoUpdate": false
